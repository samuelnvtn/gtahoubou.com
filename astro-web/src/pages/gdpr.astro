<style>
	 *{
        margin: 0;
        padding: 0;
		box-sizing: border-box;
    }

	body {
		overflow-x: hidden;
	}

    h2 {
        font-weight: 400;
		font-size: 30px;
		color:#9C2D30 ;
		margin-bottom: 20px;
		font-family: "Anton", sans-serif;
    }

    p {
        font-family: "Anton", sans-serif;
        color:#9C2D30;
        margin-bottom: 20px;
        font-size: 15px;
    }

    .content {
        display: flex;
        justify-content: center;
        background-color: #111;
		min-height: 100vh; //91vh
	}
    
    .poster{
        align-items: center;     
        text-align: center; 
        width: 50%;
        padding: 40px;
    }

    .text{
        display: flex;
        flex-direction: column;
        text-align: center;
    }

    .text2 {
        text-align: start;
    }

</style>