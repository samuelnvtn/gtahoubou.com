---
import Navigation from '../components/navbar.astro'
import Footer from '../components/footer.astro'
import obrazek from '../img/kabinet.jpg';
import obrazek2 from '../img/festival-shluk-jihlava-gtahoubou-blanc.jpg';
import obrazek3 from '../img/2328juza-vecirek1.jpg';

---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="logo_black.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Anton&display=swap" rel="stylesheet">
		<title>GTA Houbou</title>
	</head>
	<body>
		<Navigation></Navigation>

		<div class="content">
			<div class="poster">
				<i>Lístky a info o akci po kliknutí na obrázek</i>
				<h3>Poslední 2328 večírek –
				Kabinet Múz, Sukova 49/4, Brno</h3>
				<i>GTA Houbou special guest</i>
				<a href="https://goout.net/cs/2328vecirek/szjwhjy/?utm_source=ig&utm_medium=social&utm_content=link_in_bio&fbclid=PAZXh0bgNhZW0CMTEAc3J0YwZhcHBfaWQPOTM2NjE5NzQzMzkyNDU5AAGnxkVccWEIwz3VvdF9dCODg5pSqPdreROGqwb2gYxQakMwMq9dTNacvtgqrUI_aem_gxALVmsE73304VJvf3HSlQ" target="_blank">
					<img src={obrazek3.src}>
				</a>
				<h3>26. 6. 2026</h3>
			</div>
			<hr>
			<div class="poster">
				<h3>Festival SHLUK –
				Café Bar Sokolovna a DIOD Jihlava</h3>
				<a href="https://www.instagram.com/shluk.festival/p/DYjjTr7A1rk/" target="_blank">
					<img src={obrazek2.src}>
				</a>
				<h3>6. 6. 2026</h3>
			</div>
			<hr>
			<div class="poster">
						<h3>Kabinet Múz, Sukova 49/4, Brno</h3>
                        <a href="https://www.kabinetmuz.cz/program/2026-02-27-gta-houbou-blanc-live-show-" target="_blank">
                        <img src={obrazek.src}>
                        </a>
                        <h3>27. 2. 2026, 20:00 open doors</h3>
			</div>
		</div>
        
		<Footer></Footer>		
	</body>
</html>

<style>
	 *{
        margin: 0;
        padding: 0;
		box-sizing: border-box;
    }

	body {
		overflow-x: hidden;
	}

	.anton-regular {
  font-family: "Anton", sans-serif;
  font-weight: 400;
  font-style: normal;
}


	h3 {
		font-weight: 400;
		font-size: 30px;
		color:#9C2D30 ;
		margin-bottom: 10px;
		font-family: "Anton", sans-serif;
		text-align: center;
	}

	i {
		font-weight: 400;
		font-size: 20px;
		color:#9C2D30 ;
		font-family: "Anton", sans-serif;
		text-align: center;
		margin-bottom: 20px;
	}

	img {
		margin-bottom: 10px;
        transition: transform 0.3s ease-in-out;
		height: 500;        
  		width: 100%;         
  		max-width: 500px;   
	}

    img:hover {
        transform: scale(1.025);
    }

	.content {
		background-color: #111;
		min-height: 91vh; 
		flex-direction: column;
		align-items: center;
		justify-content: center;
		padding: 40px 20px;  
  		overflow-x: hidden;  
		text-align: center;
	}

	.poster {
        display: flex;           
        flex-direction: column;  
        align-items: center;     
        text-align: center;
	}

hr {
  display: block;
  height: 1px;
  border: 0;
  border-top: 3px solid #272626;
  margin-bottom: 16px;
  padding: 0;
}

@media (min-width: 769px) {
  img {
    height: 500px;
    width: auto;
    max-width: none;
  }


}
</style>
