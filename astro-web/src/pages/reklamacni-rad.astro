		color:#9C2D30 ;
		margin-bottom: 20px;
		font-family: "Anton", sans-serif;
    }

    p {
        font-family: "Anton", sans-serif;
        color:#9C2D30;
        margin-bottom: 20px;
        font-size: 15px;
    }

    .content {
        display: flex;
        justify-content: center;
        background-color: #111;
		min-height: 80vh; //91vh
        max-height: 100vh;
	}
    
    .poster{
