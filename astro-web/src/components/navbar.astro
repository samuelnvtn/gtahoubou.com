---
import logo from '../img/logo_black.png';
import stars from '../img/gta_wanted.png';
---


<div class="navbar">
    <div class="navbar-left">
          <!--
        <a href="/shop">SHOP</a>
         -->  
            <a href="/music">MUSIC</a>
            <a href="/videos">VIDEOS</a>
            <a href="/shows">SHOWS</a>
            <a href="/gta-vi">GTA VI</a>
    </div>
    <div class="navbar-logo">
        <a class="" href="/">
            <img class="logo" src={logo.src}>
        </a>
    </div>
    <div class="navbar-right">
        <img src={stars.src}>
    </div>
    <button class="menu-btn" id="menuBtn" aria-label="Otevřít menu">
        <span></span><span></span><span></span>
    </button>
</div>
<style>
    *{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    p {
        color: white;
    }

    a {
        color: #BB2B2E;
		font-family: "Anton", sans-serif;
        text-decoration: none;
        margin-right: 20px;
        font-size: 18px;
        font-weight: 400;
    }

    a:hover{
        opacity: 70%;
    }

    img{
        height: 30px;
    }

    .logo{
        height: 60px;
        display: flex;
        align-items: center;
    }

    .logo:hover {
        opacity: 70%;
        cursor: pointer;
    }

   .navbar {
        display: flex;
        position: sticky;
        top: 0;
        align-items: center;
        background-color: black;
        width: 100%;
        padding: 0px 40px;
        z-index: 999;
    }

    .navbar-left {
        flex: 1; 
        display: flex;
        justify-content: flex-start;
    }

    .navbar-logo {
        display: flex;
        flex: 0; 
        align-items: center;
    }

    .navbar-right {
        flex: 1;
        display: flex;
        justify-content: flex-end; 
    }

     /* Hamburger – schovaný na desktopu */
  .menu-btn {
    display: none;
    background: none;
    border: 2px solid #BB2B2E;
    cursor: pointer;
    padding: 10px 12px;
    flex-direction: column;
    gap: 5px;
  }

  .menu-btn span {
    display: block;
    width: 22px;
    height: 2px;
    background: #BB2B2E;
  }


    @media (max-width: 768px) {

        .navbar-left {display: none; }

        .navbar-right {justify-content: center;}

        .menu-btn { display: flex; }

        img {height: 20px;}

    }
</style>