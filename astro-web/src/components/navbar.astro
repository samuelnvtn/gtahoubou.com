---
import logo from '../img/logo_black.png';
import stars from '../img/gta_wanted.png';
---


<div class="navbar">
    <div class="navbar-left">
          <!--
        <a href="/shop">SHOP</a>
         -->  
            <a href="/music">MUSIC</a>
            <a href="/videos">VIDEOS</a>
            <a href="/shows">SHOWS</a>
            <a href="/gta-vi">GTA VI</a>
    </div>
    <div class="navbar-logo">
        <a class="" href="/">
            <img class="logo" src={logo.src}>
        </a>
    </div>
    <div class="navbar-right">
        <img src={stars.src}>
    </div>
    <button class="menu-btn" id="menuBtn" aria-label="Otevřít menu">
        <span></span><span></span><span></span>
    </button>

    <div class="mobile-menu" id="mobileMenu">
  <nav>
    <a href="/">HOME</a>
   <!--  <a href="/shop">SHOP</a> -->
    <a href="/music">MUSIC</a>
    <a href="/videos">VIDEOS</a>
    <a href="/shows">SHOWS</a>
    <a href="/gta-vi">GTA VI</a>
  </nav>
</div>
<style>
    *{
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    p {
        color: white;
    }

    a {
        color: #BB2B2E;
		font-family: "Anton", sans-serif;
        text-decoration: none;
        margin-right: 20px;
        font-size: 18px;
        font-weight: 400;
    }

    a:hover{
        opacity: 70%;
    }

    img{
        height: 30px;
    }

    .logo{
        height: 60px;
        display: flex;
        align-items: center;
    }

    .logo:hover {
        opacity: 70%;
        cursor: pointer;
    }

   .navbar {
        display: flex;
        position: sticky;
        top: 0;
        align-items: center;
        background-color: black;
        width: 100%;
        padding: 0px 40px;
        z-index: 999;
    }

    .navbar-left {
        flex: 1; 
        display: flex;
        justify-content: flex-start;
    }

    .navbar-logo {
        display: flex;
        flex: 0; 
        align-items: center;
    }

    .navbar-right {
        flex: 1;
        display: flex;
        justify-content: flex-end; 
    }

     /* Hamburger animace */
.menu-btn {
  display: none;
  background: none;
  border: 2px solid #BB2B2E;
  cursor: pointer;
  padding: 10px 12px;
  flex-direction: column;
  gap: 5px;
  transition: opacity 0.2s;
   position: relative;
  z-index: 1001;
}

.menu-btn span {
  display: block;
  width: 22px;
  height: 2px;
  background: #BB2B2E;
  transition: transform 0.5s ease, opacity 0.5s ease;
  transform-origin: center;
}

/* Mobilní menu animace */
.mobile-menu {
  display: flex;
  position: fixed;
  inset: 0;
  background: black;
  z-index: 1000;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.5s ease;
}

.mobile-menu.open {
  opacity: 1;
  pointer-events: all;
}

  .mobile-menu nav {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 28px;
  }

/* Nav linky animace */
.mobile-menu nav a {
  font-size: 40px;
  letter-spacing: 2px;
  margin-right: 0;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.mobile-menu.open nav a {
  opacity: 1;
  transform: translateY(0);
}

/* Postupné zobrazení každého linku */
.mobile-menu.open nav a:nth-child(1) { transition-delay: 0.05s; }
.mobile-menu.open nav a:nth-child(2) { transition-delay: 0.1s; }
.mobile-menu.open nav a:nth-child(3) { transition-delay: 0.15s; }
.mobile-menu.open nav a:nth-child(4) { transition-delay: 0.2s; }
.mobile-menu.open nav a:nth-child(5) { transition-delay: 0.25s; }
.mobile-menu.open nav a:nth-child(6) { transition-delay: 0.3s; }


    @media (max-width: 768px) {

        .navbar-left {display: none; }

        .navbar-right {justify-content: center;}

        .menu-btn { display: flex; }

        img {height: 20px;}

    }
</style>

<script>
const menuBtn = document.getElementById('menuBtn');
const mobileMenu = document.getElementById('mobileMenu');

function openMenu() {
  const spans = menuBtn?.querySelectorAll('span');
  mobileMenu?.classList.add('open');
  if (spans) {
    spans[0].style.transform = 'translateY(7px) rotate(45deg)';
    spans[1].style.opacity = '0';
    spans[2].style.transform = 'translateY(-7px) rotate(-45deg)';
  }
}

function closeMenu() {
  const spans = menuBtn?.querySelectorAll('span');
  mobileMenu?.classList.remove('open');
  if (spans) {
    spans[0].style.transform = '';
    spans[1].style.opacity = '';
    spans[2].style.transform = '';
  }
}

menuBtn?.addEventListener('click', () => {
  mobileMenu?.classList.contains('open') ? closeMenu() : openMenu();
});
</script>